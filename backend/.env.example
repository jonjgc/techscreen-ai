# ====================
# Application Settings
# ====================
ENVIRONMENT=development
SECRET_KEY=dev-secret-key-change-in-production-use-openssl-rand-hex-32

# ====================
# Database (PostgreSQL)
# ====================
POSTGRES_USER=techscreen
POSTGRES_PASSWORD=techscreen_pass
POSTGRES_DB=techscreen_db
DATABASE_URL=postgresql+asyncpg://techscreen:techscreen_pass@db:5432/techscreen_db

# For Alembic (sync driver) — used only for migrations
DATABASE_SYNC_URL=postgresql://techscreen:techscreen_pass@db:5432/techscreen_db

# ====================
# Redis (Celery Broker + Backend)
# ====================
REDIS_URL=redis://redis:6379/0

# ====================
# OpenAI / AI Service
# ====================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ====================
# Frontend
# ====================
NEXT_PUBLIC_API_URL=http://localhost:8000
